# Telegram Bot Configuration
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram User ID for restricted commands (e.g. /export)
# Send any message to @userinfobot on Telegram to get your ID
ADMIN_ID=YOUR_USER_ID_HERE

# Default settings
DEFAULT_PINCODE=452009
DEFAULT_CHECK_TIME=08:00

# Complete Guide URL (hosted Guide.md link)
GUIDE_URL=YOUR_LINK_HERE
